{
  "name": "syntaxis-compliance-checker",
  "displayName": "Syntaxis Compliance Checker",
  "version": "0.7.0",
  "description": "Revisa código contra Leyes 21.719 y 21.663 en tiempo real",
  "author": "Syntaxis SPA",
  "license": "MIT",
  "publisher": "syntaxis",
  "repository": {
    "type": "git",
    "url": "https://github.com/rchamycruz/compliance-checker"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "main": "./out/extension.js",
  "icon": "icon.png",
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:csharp",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onCommand:syntaxis.checkFile",
    "onCommand:syntaxis.checkWorkspace",
    "onCommand:syntaxis.generateReport"
  ],
  "contributes": {
    "commands": [
      {
        "command": "syntaxis.checkFile",
        "title": "Revisar archivo actual",
        "category": "Syntaxis"
      },
      {
        "command": "syntaxis.checkWorkspace",
        "title": "Revisar workspace completo",
        "category": "Syntaxis"
      },
      {
        "command": "syntaxis.generateReport",
        "title": "Generar reporte",
        "category": "Syntaxis"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.js",
    "compile:tsc": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "node esbuild.js && vsce package",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "^20.0.0",
    "@types/mocha": "^10.0.0",
    "typescript": "^5.0.0",
    "esbuild": "^0.20.0"
  }
}
